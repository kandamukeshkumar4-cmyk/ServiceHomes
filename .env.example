# ============================================================
# ServiceHomes Environment Configuration
# Copy this file to .env and fill in values for your environment.
# ============================================================

# --- Database ---
POSTGRES_DB=servicehomes
POSTGRES_USER=servicehomes
POSTGRES_PASSWORD=servicehomes

# --- API (Spring Boot) ---
SPRING_PROFILES_ACTIVE=local
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AWS_REGION=us-east-1
AWS_S3_BUCKET=servicehomes-media
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_ENDPOINT=http://localstack:4566
AWS_SES_ENDPOINT=http://localstack:4566
MESSAGING_EMAIL_ENABLED=false
MESSAGING_EMAIL_FROM=no-reply@servicehomes.example.com

# --- Web (Angular / Nginx) ---
NGINX_PORT=4200
API_BASE_URL=http://localhost:8080

# --- Production/Staging Overrides (replace <CHANGE_ME>) ---
# POSTGRES_PASSWORD=<CHANGE_ME>
# AUTH0_DOMAIN=<CHANGE_ME>
# AUTH0_AUDIENCE=<CHANGE_ME>
# AWS_ACCESS_KEY_ID=<CHANGE_ME>
# AWS_SECRET_ACCESS_KEY=<CHANGE_ME>
# AWS_S3_BUCKET=<CHANGE_ME>
