# ============================================================
# ServiceHomes Local Development Environment
# Copy this file to .env.local for local Docker development.
# These values are for local testing only — never commit.
# ============================================================

# --- Database (matches docker-compose defaults) ---
POSTGRES_DB=servicehomes
POSTGRES_USER=servicehomes
POSTGRES_PASSWORD=servicehomes

# --- API (local profile bypasses Auth0) ---
SPRING_PROFILES_ACTIVE=local
AUTH0_DOMAIN=local-dev-bypass
AUTH0_AUDIENCE=local-dev-bypass
AWS_REGION=us-east-1
AWS_S3_BUCKET=servicehomes-media-local
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_ENDPOINT=http://localstack:4566
AWS_SES_ENDPOINT=http://localstack:4566
MESSAGING_EMAIL_ENABLED=false
MESSAGING_EMAIL_FROM=no-reply@servicehomes.example.com

# --- Web ---
NGINX_PORT=4200
API_BASE_URL=http://localhost:8080

# --- Seeded Local Users (for reference) ---
# Local host user UUID: see V6__seed_data.sql
# Local guest user UUID: see V6__seed_data.sql
